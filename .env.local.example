# .env.local - SECRETS - DO NOT COMMIT TO GIT
# Copy this file to .env.local and fill in your actual values
# .env.local is in .gitignore and will not be committed

# NPM
export NPM_TOKEN="your_npm_token_here"

# APIGEE / WORK CREDENTIALS
export APIGEE_MGMT_BASE_URL="your_apigee_url"
export APIGEE_BASIC_USER="your_email@company.com"
export APIGEE_BASIC_PASS='your_password'

# WPSCAN (if needed)
# export WPSCAN_API_TOKEN=your_token_here

# BEEHIIV (if needed)
# export BEEHIIV_PUBLICATION_ID=your_pub_id
# export BEEHIIV_API_KEY=your_api_key

# OPENAI
# export OPENAI_API_KEY=your_openai_key
# export OPENAI_ORG_ID=your_org_id
# export SGPT_MODEL=gpt-4o-mini

# ANTHROPIC
# export ANTHROPIC_API_KEY=your_anthropic_key
